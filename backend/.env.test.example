NODE_ENV=test
PORT=3001

DATABASE_URL=postgresql://admin:<password>@localhost:5432/neobooru_test

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=300
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_COMMENTS_WINDOW_SECONDS=60
RATE_LIMIT_COMMENTS_MAX=30

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=<password>
MINIO_BUCKET=media-test
MINIO_PRESIGN_EXPIRES=3600

MAX_UPLOAD_BYTES=104857600

JWT_SECRET=<min-32-chars-secret>
JWT_EXPIRES_IN=60
JWT_REFRESH_SECRET=<min-32-chars-secret>
JWT_REFRESH_EXPIRES_IN=300

JOBS_ENABLED=false
JOBS_RUN_ON_START=false

LOG_LEVEL=silent
LOG_TO_FILE=false
LOG_CONSOLE_FORMAT=json
LOG_FILE_FORMAT=json
LOG_PRETTY_COLOR=false
LOG_HTTP_HEADERS=false
LOG_HEALTHCHECKS=false
