# Copy to docker/.env or export these variables before running compose.

FRONTEND_PORT=8080
BACKEND_PORT=3000
PUBLIC_APP_URL=http://localhost:8080

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=neobooru
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_DB=0

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
MINIO_BUCKET=media
MINIO_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false

JWT_SECRET=change-me-change-me-change-me-change-me-1
JWT_REFRESH_SECRET=change-me-change-me-change-me-change-me-2

LOG_LEVEL=info
LOG_TO_FILE=false
RUN_MIGRATIONS=true

# First admin bootstrap. Backend creates this account only while there is no
# user with the admin role yet. Change the password before exposing the stack.
SEED_ADMIN_EMAIL=admin@local.dev
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345
SEED_DEV_USERS=false
